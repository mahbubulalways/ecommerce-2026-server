// ENUM
enum USER_ROLE {
  ADMIN
  SUPER_ADMIN
  CONSUMER
}

enum USER_STATUS {
  ACTIVE
  INACTIVE
  BANNED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum PRODUCT_STATUS {
  IN_STOCK
  STOCK_OUT
}
